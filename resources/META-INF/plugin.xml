        <themeProvider
                id="f3a4b5c6-d7e8-9f0a-1b2c-3d4e5f607182"
                path="/theme/KIThemesCosmicHorror.theme.json"/>
        <bundledColorScheme id="KIThemes Cosmic Horror" path="/META-INF/KIThemesCosmicHorror"/>
    </extensions>
</idea-plugin>
